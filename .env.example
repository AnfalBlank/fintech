# Database — Turso libSQL
TURSO_DATABASE_URL="libsql://your-database.turso.io"
TURSO_AUTH_TOKEN="your-token"

# JWT signing — generate with: openssl rand -base64 32
JWT_SECRET="your-strong-jwt-secret"

# App env (development|staging|production)
APP_ENV="development"

# Midtrans (sandbox/production)
MIDTRANS_SERVER_KEY=""
MIDTRANS_PRODUCTION="false"

# Cloudflare R2 storage (S3-compatible)
R2_ENDPOINT="https://<account>.r2.cloudflarestorage.com/<bucket>"
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_PUBLIC_BASE_URL=""

# Sentry (optional)
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# Upstash Redis rate limit (optional, falls back to in-memory)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
